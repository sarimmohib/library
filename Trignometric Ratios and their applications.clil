        on_correct: {
            feedback: "Right! Using Formula 38: 2 sinA cosB = sin(A+B) + sin(A-B) = sin 60° + sin 40°.";
            goto "q_ps2";
        }
        on_wrong: {
            feedback: "Formula 38: 2 sinA cosB = sin(A+B) + sin(A-B). With A=50°, B=10°: sin 60° + sin 40°.";
            @loopback "product_sum" {
                $review_count = $review_count + 1;
            }
        }
    }

    mcq "q_ps2" {
        Q: "cos 75° × cos 15° equals:";
        A: "a";
        O: a) "1/4", b) "1/2", c) "√3/4", d) "0";
        on_correct: {
            feedback: "Excellent! ½[cos(75-15) + cos(75+15)] = ½[cos 60° + cos 90°] = ½[1/2 + 0] = 1/4.";
            goto "triple_angle";
        }
        on_wrong: {
            feedback: "Use Formula 37: cosA cosB = ½[cos(A-B)+cos(A+B)] = ½[cos 60°+cos 90°] = ½[1/2+0] = 1/4.";
