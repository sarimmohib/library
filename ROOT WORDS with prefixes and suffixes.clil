scene "toc_scene" {
    index: "a0";
    title: "Table of Contents - Vocabulary Mastery";
    toc {
        style: "numbered";
        clickable: true;
    }
}

scene "intro" {
    index: "a1";
    concept: "vocabulary_fundamentals";
    title: "Introduction to Vocabulary Building";
    format: "markdown";
    body: """
        ## Master Vocabulary: Your Key to Language Excellence
        
        Welcome to this comprehensive vocabulary lesson! You'll learn:
        
        ### What We'll Cover:
        1. **Root Words** - The foundation of meaning
        2. **Prefixes** - Adding meaning to the beginning
        3. **Suffixes** - Adding meaning to the end
        4. **Synonyms & Antonyms** - Expanding your word power
        5. **Parts of Speech** - Nouns, Adjectives, Verbs, Adverbs
        6. **100+ Examples** with practical applications
        7. **MCQs & Aptitude Tests** with speed-solving strategies
        
        ### Why This Matters:
        - {bold}Score higher{/bold} on standardized tests
        - {bold}Read faster{/bold} with better comprehension
        - {bold}Write better{/bold} with precise word choice
        - {bold}Think clearer{/bold} with expanded vocabulary
        
        > **Pro Tip:** Understanding word structure helps you decode {color:blue}thousands{/color} of unfamiliar words!
    """;
    goto "root_words_intro";
}

scene "root_words_intro" {
    index: "b1";
    concept: "root_words";
    title: "Understanding Root Words - Part 1";
    format: "markdown";
    body: """
        ## What Are Root Words?
        
        A {highlight:#ffff00}root word{/highlight} is the basic form of a word that carries its core meaning.         By adding prefixes and suffixes, we create new words.
        
        ### Example Breakdown:
        
        **Root: SPECT** (meaning: to look/see)
        
        | Word | Prefix | Root | Suffix | Meaning |
        |------|--------|------|--------|---------|
        | Inspect | in- (into) | spect | - | to look into |
        | Respect | re- (back) | spect | - | to look back at |
        | Spectator | - | spect | -ator (one who) | one who watches |
        | Spectacle | - | spect | -acle (thing) | something seen |
        
        ### {bold}10 Common Root Words with Examples:{/bold}
        
        1. **AUD** (hear) → audio, audience, audible, auditorium, audit
        2. **BIO** (life) → biology, biography, biosphere, antibiotic, biodegradable
        3. **CHRON** (time) → chronicle, chronology, chronic, synchronize, anachronism
        4. **DICT** (say/speak) → dictate, predict, contradict, dictionary, verdict
        5. **GRAPH** (write) → graphic, biography, autograph, photograph, paragraph
        6. **JUR/JUS** (law) → jury, justice, justify, jurisprudence, perjury
        7. **MAN** (hand) → manual, manufacture, manuscript, manage, maneuver
        8. **PORT** (carry) → transport, portable, import, export, porter
        9. **STRUCT** (build) → structure, construct, instruct, destruction, infrastructure
        10. **VID/VIS** (see) → video, vision, visible, invisible, supervise
    """;
    simulation "root_visualizer" {
        description: "Interactive Root Word Builder - See how roots form words";
        raw: """
            <div style="background:#f0f8ff;padding:20px;border-radius:10px;">
                <h3 style="color:#2c3e50;">Root Word Visualizer</h3>
                <div style="margin:15px 0;">
                    <label>Select a Root: </label>
                    <select id="rootSelect" style="padding:8px;font-size:14px;">
                        <option value="spect">SPECT (look/see)</option>
                        <option value="aud">AUD (hear)</option>
                        <option value="bio">BIO (life)</option>
                        <option value="dict">DICT (say/speak)</option>
                        <option value="port">PORT (carry)</option>
                    </select>
                </div>
                <div id="rootDisplay" style="background:white;padding:15px;border-left:4px solid #3498db;margin:10px 0;">
                    <strong>Root:</strong> <span id="rootMeaning"></span>
                    <div id="wordExamples" style="margin-top:10px;"></div>
                </div>
                <button onclick="buildWord()" style="background:#3498db;color:white;padding:10px 20px;border:none;border-radius:5px;cursor:pointer;margin-top:10px;">
                    Build a Word
                </button>
                <div id="builtWord" style="margin-top:15px;font-size:18px;font-weight:bold;color:#e74c3c;"></div>
            </div>            <script>
                const rootData = {
                    spect: {meaning: 'to look/see', words: ['inspect', 'respect', 'spectator', 'spectacle', 'prospect', 'retrospect']},
                    aud: {meaning: 'to hear', words: ['audio', 'audience', 'audible', 'auditorium', 'audit', 'auditory']},
                    bio: {meaning: 'life', words: ['biology', 'biography', 'biosphere', 'antibiotic', 'biodegradable', 'bioluminescent']},
                    dict: {meaning: 'to say/speak', words: ['dictate', 'predict', 'contradict', 'dictionary', 'verdict', 'dictator']},
                    port: {meaning: 'to carry', words: ['transport', 'portable', 'import', 'export', 'porter', 'portfolio']}
                };
                
                document.getElementById('rootSelect').addEventListener('change', function() {
                    const root = this.value;
                    document.getElementById('rootMeaning').textContent = rootData[root].meaning;
                    document.getElementById('wordExamples').innerHTML = 
                        '<strong>Words:</strong> ' + rootData[root].words.join(', ');
                });
                
                document.getElementById('rootSelect').dispatchEvent(new Event('change'));
                
                function buildWord() {
                    const root = document.getElementById('rootSelect').value;
                    const prefixes = ['in-', 're-', 'pro-', 'pre-', 'ex-', 'im-', 'un-', 'dis-'];
                    const suffixes = ['-or', '-ion', '-ive', '-able', '-ing', '-ed', '-ment', '-er'];
                    const words = rootData[root].words;
                    const randomWord = words[Math.floor(Math.random() * words.length)];
                    document.getElementById('builtWord').innerHTML = 
                        'Generated Word: <span style="color:#27ae60;">' + randomWord + '</span><br>' +
                        '<small>Can you identify the prefix, root, and suffix?</small>';
                }
            </script>
        """;
    }
}

scene "root_words_part2" {
    index: "b2";
    concept: "root_words";
    title: "Root Words - Part 2 (20 More Examples)";
    format: "markdown";
    body: """
        ## Advanced Root Words (11-30)
        
        11. **SCRIBE/SCRIPT** (write) → scribe, describe, prescription, manuscript, scripture, postscript
        12. **TERR** (earth/land) → terrain, territory, terrestrial, terrace, terrarium, subterranean
        13. **AQUA** (water) → aquarium, aquatic, aqueduct, aquamarine, aquifer, aquaculture
        14. **BENE** (good/well) → benefit, benevolent, benediction, benefactor, benign, benefice
        15. **MAL** (bad/evil) → malice, malicious, malfunction, malnutrition, malpractice, malevolent
        16. **MAGN** (great/large) → magnificent, magnify, magnitude, magnanimous, magnet, magnifier
        17. **MULTI** (many) → multiple, multiply, multitude, multicultural, multimedia, multilingual
        18. **NOV** (new) → novel, innovate, renovate, novelty, novice, innovation
        19. **OMNI** (all) → omniscient, omnipotent, omnipresent, omnivore, omnidirectional, omnibus        20. **PATH** (feeling/disease) → sympathy, pathology, empathy, apathy, psychopath, neuropathy
        
        21. **PED** (foot/child) → pedestrian, pedal, centipede, expedite, impede, pedicure
        22. **PHON** (sound) → telephone, phonics, symphony, microphone, euphony, cacophony
        23. **PHOTO** (light) → photograph, photosynthesis, photon, photocopy, photogenic, photovoltaic
        24. **POLY** (many) → polygon, polytechnic, polygamy, polyester, polytheism, polyclinic
        25. **POPUL** (people) → population, popular, populate, populace, depopulate, populism
        26. **QUER/QUES** (ask/search) → question, query, inquire, quest, request, exquisite
        27. **RUPT** (break) → rupture, interrupt, corrupt, erupt, bankrupt, disruption
        28. **SCI** (know) → science, conscious, omniscient, prescience, science fiction, scientist
        29. **SENS/SENT** (feel) → sensitive, sentiment, consent, sensation, resent, sensible
        30. **THERM** (heat) → thermometer, thermal, thermos, geothermal, thermostat, thermodynamics
        
        ### {bold}Practice Exercise:{/bold}
        Match the root to its meaning:
        - AQUA → water
        - BENE → good
        - MAL → bad
        - MAGN → large
        - OMNI → all
    """;
    mcq "root_quiz1" {
        Q: "The root 'BENE' in 'benevolent' means:";
        A: "b) Good";
        O: a) "Bad", b) "Good", c) "Large", d) "Small";
        R: "BENE means 'good' or 'well'. Benevolent = well-wishing, kind.";
        on_correct: {
            feedback: "Excellent! You understand root meanings.";
            goto "prefixes_intro";
        }
        on_wrong: {
            feedback: "Review: BENE = good (benefit, benevolent, benediction)";
            @loopback "root_words_part2" {
                $root_attempts = $root_attempts + 1;
            }
        }
    }
}

scene "prefixes_intro" {
    index: "c1";
    concept: "prefixes";
    title: "Mastering Prefixes - Part 1";
    format: "markdown";
    body: """
        ## What Are Prefixes?
        
        A {highlight:#ffff00}prefix{/highlight} is added to the {bold}beginning{/bold} of a root word to change its meaning.
        
        ### {bold}Common Prefix Categories:{/bold}        
        #### 1. NEGATION PREFIXES (make negative):
        - **UN-** (not) → unhappy, unfair, unlock, unknown, unusual, unnecessary
        - **IN-/IM-/IL-/IR-** (not) → inactive, impossible, illegal, irregular, invisible, immature
        - **DIS-** (not/opposite) → disagree, disappear, dishonest, disconnect, dislike, disapprove
        - **NON-** (not) → nonsense, nonstop, nonprofit, nonfiction, nonviolent, nonexistent
        
        #### 2. DIRECTION/POSITION PREFIXES:
        - **PRE-** (before) → preview, preheat, prehistoric, prepaid, precaution, prearrange
        - **POST-** (after) → postpone, postscript, postwar, postgraduate, postmortem, postdate
        - **SUB-** (under) → submarine, subzero, subtitle, subway, substandard, subconscious
        - **INTER-** (between) → international, interact, intercept, interlock, intermission, interstate
        - **TRANS-** (across) → transport, transatlantic, transfuse, transcribe, transplant, transform
        
        #### 3. NUMBER/QUANTITY PREFIXES:
        - **UNI-** (one) → uniform, unicorn, unilateral, unicycle, unify, unique
        - **BI-** (two) → bicycle, bilingual, biannual, bilateral, bisect, bipartisan
        - **TRI-** (three) → triangle, tricycle, trilogy, trilingual, trisect, tripod
        - **MULTI-** (many) → multiply, multicultural, multimedia, multilingual, multitask, multiverse
        - **SEMI-** (half) → semicircle, semifinal, semicolon, semiconductor, semiannual, semiconscious
        
        ### Examples in Context:
        1. **UNpredictable** = not predictable
        2. **RE**write = write again
        3. **DIS**agree = not agree
        4. **PRE**view = view before
        5. **SUB**marine = under the sea
    """;
    simulation "prefix_builder" {
        description: "Interactive Prefix Word Builder";
        raw: """
            <div style="background:#fff3cd;padding:20px;border-radius:10px;">
                <h3 style="color:#856404;">Prefix Word Builder</h3>
                <div style="display:flex;gap:10px;margin:15px 0;flex-wrap:wrap;">
                    <select id="prefixSelect" style="padding:8px;font-size:14px;">
                        <option value="">Select Prefix</option>
                        <option value="un-">UN- (not)</option>
                        <option value="re-">RE- (again)</option>
                        <option value="dis-">DIS- (opposite)</option>
                        <option value="pre-">PRE- (before)</option>
                        <option value="mis-">MIS- (wrong)</option>
                        <option value="over-">OVER- (too much)</option>
                        <option value="sub-">SUB- (under)</option>
                        <option value="inter-">INTER- (between)</option>
                    </select>
                    <select id="rootSelect2" style="padding:8px;font-size:14px;">
                        <option value="">Select Root</option>
                        <option value="happy">happy</option>
                        <option value="write">write</option>
                        <option value="agree">agree</option>                        <option value="view">view</option>
                        <option value="understand">understand</option>
                        <option value="act">act</option>
                        <option value="connect">connect</option>
                        <option value="national">national</option>
                    </select>
                </div>
                <button onclick="combinePrefix()" style="background:#856404;color:white;padding:10px 20px;border:none;border-radius:5px;cursor:pointer;">
                    Combine
                </button>
                <div id="prefixResult" style="margin-top:15px;padding:15px;background:white;border-radius:5px;display:none;">
                    <div style="font-size:24px;font-weight:bold;color:#2c3e50;" id="combinedWord"></div>
                    <div style="margin-top:10px;color:#666;" id="prefixMeaning"></div>
                </div>
            </div>
            <script>
                const prefixMeanings = {
                    'un-': 'not', 're-': 'again', 'dis-': 'opposite/not', 'pre-': 'before',
                    'mis-': 'wrongly', 'over-': 'too much', 'sub-': 'under', 'inter-': 'between'
                };
                
                function combinePrefix() {
                    const prefix = document.getElementById('prefixSelect').value;
                    const root = document.getElementById('rootSelect2').value;
                    if (prefix && root) {
                        const word = prefix + root;
                        document.getElementById('combinedWord').textContent = word;
                        document.getElementById('prefixMeaning').innerHTML = 
                            '<strong>' + prefix + '</strong> (' + prefixMeanings[prefix] + ') + ' + 
                            '<strong>' + root + '</strong> = ' + word;
                        document.getElementById('prefixResult').style.display = 'block';
                    } else {
                        alert('Please select both a prefix and a root word!');
                    }
                }
            </script>
        """;
    }
}

scene "prefixes_part2" {
    index: "c2";
    concept: "prefixes";
    title: "Prefixes - Part 2 (30 More Examples)";
    format: "markdown";
    body: """
        ## Advanced Prefixes (9-20)
        
        9. **RE-** (again/back) → rewrite, rebuild, return, replay, reconsider, reconnect, recharge, reorganize
        10. **MIS-** (wrong/badly) → misunderstand, misbehave, mislead, misplace, misinform, misjudge, miscalculate        11. **OVER-** (too much/above) → overeat, overwork, overpay, overestimate, overlook, overreact, overconfident
        12. **UNDER-** (too little/below) → underestimate, underpaid, undercooked, underground, underachieve, underwear
        13. **SUPER-** (above/beyond) → supermarket, supernatural, superhuman, superimpose, superstructure, supersede
        14. **ANTI-** (against) → antibiotic, antifreeze, anticlockwise, antisocial, antibody, antiaircraft
        15. **AUTO-** (self) → autobiography, automobile, automatic, autofocus, autograph, autopilot
        16. **CO-** (together/with) → cooperate, coauthor, coworker, coexist, codirect, coproduce
        17. **DE-** (remove/reverse) → devalue, defrost, decode, dehydrate, demotivate, decentralize
        18. **EX-** (out/former) → exit, exhale, extract, ex-president, ex-boyfriend, export, exclude
        19. **FORE-** (before/ahead) → forecast, forehead, forewarn, foretell, forefather, foreground, foresee
        20. **HYPER-** (excessive/above) → hyperactive, hypersensitive, hyperlink, hypertension, hyperventilate
        
        ### {bold}More Prefix Examples (21-30):{/bold}
        
        21. **IL-/IM-/IR-** (not - variants of IN-) → illegal, immature, irresponsible, illogical, imbalance, irregular
        22. **IN-/IG-** (not/into) → inactive, invisible, ingroup, ignite, input, inject, ignore
        23. **INFRA-** (below) → infrastructure, infrared, infrasonic, inframarginal
        24. **MAL-** (bad) → malfunction, malnutrition, malpractice, malcontent, malodorous
        25. **META-** (beyond/change) → metamorphosis, metadata, metaphysics, metaphor, metabolize
        26. **OUT-** (exceed/beyond) → outnumber, outperform, outrun, outsmart, outgrow, outlast
        27. **PER-** (through) → permeate, perforate, permanent, persist, pervade, percolate
        28. **PRO-** (for/before) → proactive, pro-government, proceed, progress, promote, propel
        29. **QUASI-** (almost/seeming) → quasi-scientific, quasi-judicial, quasi-stable
        30. **ULTRA-** (beyond/extreme) → ultraviolet, ultrasound, ultramodern, ultramarine, ultrasonic
        
        ### {bold}Speed Tip for Tests:{/bold}
        When you see an unfamiliar word:
        1. Identify the {color:blue}prefix{/color}
        2. Find the {color:blue}root{/color}
        3. Check for {color:blue}suffix{/color}
        4. Combine meanings = Approximate definition
        
        Example: **UNPREDICTABLE**
        - UN- = not
        - PREDICT = to say beforehand
        - -ABLE = capable of
        - Meaning: not capable of being said beforehand
    """;
    mcq "prefix_quiz1" {
        Q: "What does 'MIS' mean in 'MISUNDERSTAND'?";
        A: "b) Wrongly";
        O: a) "Again", b) "Wrongly", c) "Before", d) "After";
        R: "MIS- means 'wrongly' or 'badly'. Misunderstand = to understand wrongly.";
        on_correct: {
            feedback: "Perfect! You're mastering prefixes!";
            goto "suffixes_intro";
        }
        on_wrong: {
            feedback: "Remember: MIS- = wrongly (misbehave, mislead, misplace)";
            @loopback "prefixes_part2" {
                $prefix_attempts = $prefix_attempts + 1;            }
        }
    }
}

scene "suffixes_intro" {
    index: "d1";
    concept: "suffixes";
    title: "Understanding Suffixes - Part 1";
    format: "markdown";
    body: """
        ## What Are Suffixes?
        
        A {highlight:#ffff00}suffix{/highlight} is added to the {bold}end{/bold} of a root word to:
        - Change its part of speech (noun→adjective, verb→noun, etc.)
        - Modify its meaning
        - Indicate tense, number, or comparison
        
        ### {bold}NOUN-FORMING SUFFIXES:{/bold}
        
        1. **-TION/-SION** (action/state) → action, creation, decision, vision, information, education
        2. **-ER/-OR** (person who does) → teacher, worker, actor, director, singer, creator
        3. **-NESS** (state/quality) → happiness, sadness, kindness, darkness, weakness, fitness
        4. **-MENT** (action/result) → movement, development, agreement, enjoyment, achievement
        5. **-ITY** (state/quality) → ability, possibility, reality, curiosity, activity, diversity
        6. **-ANCE/-ENCE** (state/quality) → importance, difference, existence, resistance, patience
        7. **-ISM** (doctrine/practice) → capitalism, socialism, optimism, pessimism, criticism
        8. **-IST** (person who practices) → artist, scientist, tourist, pianist, dentist, biologist
        
        ### {bold}ADJECTIVE-FORMING SUFFIXES:{/bold}
        
        9. **-FUL** (full of) → beautiful, helpful, careful, wonderful, grateful, powerful
        10. **-LESS** (without) → hopeless, careless, useless, endless, fearless, homeless
        11. **-ABLE/-IBLE** (capable of) → readable, comfortable, possible, visible, flexible, edible
        12. **-OUS** (full of) → dangerous, famous, nervous, glorious, poisonous, courageous
        13. **-IVE** (tending to) → active, creative, expensive, attractive, sensitive, decisive
        14. **-AL** (relating to) → natural, musical, logical, personal, cultural, magical
        15. **-IC** (relating to) → heroic, poetic, artistic, scientific, historic, energetic
        
        ### {bold}VERB-FORMING SUFFIXES:{/bold}
        
        16. **-IZE/-ISE** (make/become) → realize, organize, modernize, apologize, recognize, criticize
        17. **-EN** (make) → strengthen, weaken, widen, shorten, darken, soften
        18. **-FY** (make) → simplify, clarify, beautify, justify, satisfy, modify
        
        ### {bold}ADVERB-FORMING SUFFIX:{/bold}
        
        19. **-LY** (in a manner) → quickly, slowly, happily, carefully, beautifully, easily
    """;
    simulation "suffix_transformer" {        description: "Interactive Suffix Transformer - Change Parts of Speech";
        raw: """
            <div style="background:#d5f5e3;padding:20px;border-radius:10px;">
                <h3 style="color:#27ae60;">Suffix Transformer</h3>
                <p>Transform words by adding suffixes!</p>
                <div style="margin:15px 0;">
                    <label>Base Word: </label>
                    <input type="text" id="baseWord" placeholder="e.g., happy" style="padding:8px;font-size:14px;width:150px;">
                </div>
                <div style="margin:15px 0;">
                    <label>Add Suffix: </label>
                    <select id="suffixSelect" style="padding:8px;font-size:14px;">
                        <option value="-ness">-NESS (makes noun)</option>
                        <option value="-ly">-LY (makes adverb)</option>
                        <option value="-ful">-FUL (makes adjective)</option>
                        <option value="-less">-LESS (makes adjective)</option>
                        <option value="-er">-ER (makes noun)</option>
                        <option value="-ize">-IZE (makes verb)</option>
                        <option value="-able">-ABLE (makes adjective)</option>
                        <option value="-ment">-MENT (makes noun)</option>
                    </select>
                </div>
                <button onclick="transformWord()" style="background:#27ae60;color:white;padding:10px 20px;border:none;border-radius:5px;cursor:pointer;">
                    Transform
                </button>
                <div id="transformResult" style="margin-top:15px;padding:15px;background:white;border-radius:5px;display:none;">
                    <div style="font-size:20px;font-weight:bold;color:#2c3e50;" id="newWord"></div>
                    <div style="margin-top:10px;color:#666;" id="transformation"></div>
                </div>
            </div>
            <script>
                function transformWord() {
                    const base = document.getElementById('baseWord').value.trim();
                    const suffix = document.getElementById('suffixSelect').value;
                    if (base) {
                        let transformed = base + suffix;
                        if (base.endsWith('y') && (suffix === '-ness' || suffix === '-ly' || suffix === '-er')) {
                            transformed = base.slice(0, -1) + 'i' + suffix;
                        }
                        if (base.endsWith('e') && suffix === '-ize') {
                            transformed = base + suffix;
                        }
                        document.getElementById('newWord').textContent = transformed;
                        document.getElementById('transformation').innerHTML = 
                            base + ' + ' + suffix + ' = <strong>' + transformed + '</strong>';
                        document.getElementById('transformResult').style.display = 'block';
                    } else {
                        alert('Please enter a base word!');
                    }
                }            </script>
        """;
    }
}

scene "suffixes_part2" {
    index: "d2";
    concept: "suffixes";
    title: "Suffixes - Part 2 (30 More Examples)";
    format: "markdown";
    body: """
        ## Advanced Suffix Examples (20-40)
        
        20. **-AGE** (action/collection) → marriage, passage, baggage, percentage, advantage, wreckage
        21. **-AL** (act of/process) → arrival, refusal, approval, denial, proposal, revival
        22. **-ARY** (relating to/place) → library, dictionary, secretary, imaginary, temporary
        23. **-CY** (state/quality) → accuracy, privacy, urgency, democracy, bankruptcy, constancy
        24. **-DOM** (state/domain) → freedom, kingdom, wisdom, boredom, randomness, martyrdom
        25. **-ERY** (place/practice) → bakery, brewery, robbery, slavery, machinery, cookery
        26. **-HOOD** (state/period) → childhood, brotherhood, neighborhood, likelihood, falsehood
        27. **-ING** (action/result) → building, feeling, meeting, painting, ending, opening
        28. **-SHIP** (state/skill) → friendship, leadership, relationship, hardship, ownership
        29. **-TH** (state/quality) → truth, depth, width, growth, strength, warmth
        
        ### {bold}More Adjective Suffixes:{/bold}
        30. **-ANT/-ENT** (performing) → important, different, excellent, pleasant, resistant, dependent
        31. **-ISH** (somewhat/like) → childish, foolish, selfish, reddish, selfish, bookish
        32. **-LIKE** (similar to) → childlike, lifelike, businesslike, ladylike, warlike, godlike
        33. **-Y** (full of/characterized by) → sunny, rainy, cloudy, windy, dusty, noisy
        
        ### {bold}Verb Suffixes (continued):{/bold}
        34. **-ATE** (make/do) → activate, create, communicate, celebrate, educate, motivate
        35. **-ISH** (cause to be) → finish, punish, establish, diminish, accomplish, distinguish
        
        ### {bold}Diminutive Suffixes (small/young):{/bold}
        36. **-LET** (small) → booklet, leaflet, droplet, piglet, ringlet, starlet
        37. **-LING** (small/young) → duckling, sapling, seedling, fledgling, catling
        38. **-ETTE** (small/feminine) → kitchenette, cigarette, statuette, usherette, suffragette
        
        ### {bold}Comparative/Superlative Suffixes:{/bold}
        39. **-ER** (comparative) → faster, taller, bigger, smarter, happier, stronger
        40. **-EST** (superlative) → fastest, tallest, biggest, smartest, happiest, strongest
        
        ### {bold}Test-Taking Strategy:{/bold}
        When analyzing a word:
        1. Strip off the {color:blue}suffix{/color} first
        2. Identify the {color:blue}root{/color}
        3. Check for {color:blue}prefix{/color}
        4. Determine part of speech from suffix
                Example: **UNCOMFORTABLE**
        - Suffix: -ABLE (adjective suffix = capable of)
        - Root: COMFORT
        - Prefix: UN- (not)
        - Part of speech: Adjective
        - Meaning: not capable of being comforted
    """;
    mcq "suffix_quiz1" {
        Q: "Which suffix would you add to 'BEAUTY' to make it an adjective?";
        A: "b) -FUL";
        O: a) "-NESS", b) "-FUL", c) "-MENT", d) "-TION";
        R: "-FUL makes adjectives. BEAUTY + FUL = BEAUTIFUL (adjective). -NESS makes nouns (beauty + ness = beautifulness).";
        on_correct: {
            feedback: "Excellent! You understand how suffixes change parts of speech!";
            goto "synonyms_antonyms";
        }
        on_wrong: {
            feedback: "Review: -FUL creates adjectives (beautiful, helpful, careful)";
            @loopback "suffixes_part2" {
                $suffix_attempts = $suffix_attempts + 1;
            }
        }
    }
}

scene "synonyms_antonyms" {
    index: "e1";
    concept: "synonyms_antonyms";
    title: "Synonyms and Antonyms Mastery";
    format: "markdown";
    body: """
        ## Synonyms (Words with Similar Meanings)
        
        {highlight:#ffff00}Synonyms{/highlight} help you vary your language and avoid repetition.
        
        ### {bold}50 Common Synonym Groups:{/bold}
        
        1. **HAPPY** → joyful, cheerful, delighted, pleased, content, ecstatic, elated, glad
        2. **SAD** → unhappy, sorrowful, melancholy, depressed, gloomy, mournful, dejected
        3. **BIG** → large, huge, enormous, massive, gigantic, colossal, tremendous, vast
        4. **SMALL** → tiny, little, miniature, petite, compact, minute, microscopic
        5. **FAST** → quick, rapid, swift, speedy, hasty, fleet, expeditious
        6. **SLOW** → sluggish, leisurely, gradual, unhurried, plodding, lethargic
        7. **GOOD** → excellent, fine, superior, admirable, wonderful, marvelous, great
        8. **BAD** → poor, terrible, awful, dreadful, horrible, inferior, negative
        9. **SMART** → intelligent, clever, bright, brilliant, wise, ingenious, astute
        10. **STRONG** → powerful, mighty, robust, sturdy, vigorous, forceful, tough
        
        11. **WEAK** → feeble, frail, fragile, delicate, flimsy, powerless, vulnerable
        12. **BEAUTIFUL** → gorgeous, stunning, attractive, lovely, pretty, elegant, exquisite        13. **UGLY** → unattractive, hideous, unsightly, grotesque, repulsive, plain
        14. **BRAVE** → courageous, fearless, valiant, heroic, bold, daring, gallant
        15. **AFRAID** → frightened, scared, terrified, fearful, anxious, nervous, apprehensive
        16. **ANGRY** → furious, enraged, irate, livid, incensed, wrathful, indignant
        17. **CALM** → peaceful, tranquil, serene, composed, relaxed, placid, untroubled
        18. **DIFFICULT** → hard, challenging, complex, complicated, arduous, demanding
        19. **EASY** → simple, effortless, easy, uncomplicated, straightforward, painless
        20. **IMPORTANT** → significant, crucial, vital, essential, critical, major, paramount
        
        21. **UNIMPORTANT** → trivial, insignificant, minor, negligible, petty, irrelevant
        22. **RICH** → wealthy, affluent, prosperous, opulent, well-off, moneyed
        23. **POOR** → impoverished, needy, destitute, penniless, indigent, underprivileged
        24. **FAMOUS** → renowned, celebrated, distinguished, eminent, well-known, prominent
        25. **UNKNOWN** → obscure, anonymous, unfamiliar, unrecognized, nameless
        26. **OLD** → ancient, elderly, aged, antique, archaic, obsolete, vintage
        27. **NEW** → modern, recent, fresh, novel, contemporary, current, latest
        28. **HOT** → warm, heated, scorching, boiling, sizzling, sweltering, torrid
        29. **COLD** → chilly, frigid, freezing, icy, frosty, arctic, gelid
        30. **CLEAN** → spotless, pure, immaculate, pristine, sanitary, unsoiled
        
        31. **DIRTY** → filthy, soiled, unclean, contaminated, polluted, grimy
        32. **BRIGHT** → brilliant, radiant, luminous, shining, glowing, dazzling
        33. **DARK** → dim, gloomy, shadowy, obscure, murky, dusky, unlit
        34. **LOUD** → noisy, deafening, thunderous, boisterous, clamorous, raucous
        35. **QUIET** → silent, hushed, noiseless, peaceful, still, tranquil
        36. **KIND** → gentle, compassionate, considerate, thoughtful, benevolent, caring
        37. **CRUEL** → harsh, brutal, vicious, merciless, ruthless, inhumane, savage
        38. **HONEST** → truthful, sincere, genuine, frank, trustworthy, upright
        39. **DISHONEST** → deceitful, dishonest, fraudulent, deceptive, lying, untruthful
        40. **HELPFUL** → useful, beneficial, supportive, advantageous, constructive
        
        41. **HARMFUL** → damaging, destructive, detrimental, injurious, hazardous, perilous
        42. **SUCCESS** → achievement, accomplishment, triumph, victory, attainment
        43. **FAILURE** → defeat, flop, disappointment, collapse, breakdown, miscarriage
        44. **BEGIN** → start, commence, initiate, launch, embark, inaugurate
        45. **END** → finish, conclude, terminate, complete, cease, close
        46. **LOVE** → adore, cherish, treasure, esteem, revere, idolize, worship
        47. **HATE** → despise, detest, loathe, abhor, dislike, resent, abominate
        48. **THINK** → believe, consider, ponder, contemplate, reflect, reason
        49. **SAY** → state, declare, express, utter, articulate, verbalize, pronounce
        50. **WALK** → stroll, amble, saunter, stride, march, trek, hike
        
        ## Antonyms (Words with Opposite Meanings)
        
        {highlight:#ffff00}Antonyms{/highlight} help you understand contrast and nuance.
        
        ### {bold}30 Essential Antonym Pairs:{/bold}
        
        1. **HOT** ↔ **COLD**
        2. **FAST** ↔ **SLOW**        3. **UP** ↔ **DOWN**
        4. **LEFT** ↔ **RIGHT**
        5. **BIG** ↔ **SMALL**
        6. **OPEN** ↔ **CLOSED**
        7. **LIGHT** ↔ **DARK**
        8. **HAPPY** ↔ **SAD**
        9. **LOVE** ↔ **HATE**
        10. **WIN** ↔ **LOSE**
        
        11. **ALIVE** ↔ **DEAD**
        12. **YOUNG** ↔ **OLD**
        13. **STRONG** ↔ **WEAK**
        14. **RICH** ↔ **POOR**
        15. **FAMOUS** ↔ **UNKNOWN**
        16. **CLEAN** ↔ **DIRTY**
        17. **LOUD** ↔ **QUIET**
        18. **BRAVE** ↔ **COWARDLY**
        19. **HONEST** ↔ **DISHONEST**
        20. **KIND** ↔ **CRUEL**
        
        21. **SIMPLE** ↔ **COMPLEX**
        22. **PUBLIC** ↔ **PRIVATE**
        23. **NATURAL** ↔ **ARTIFICIAL**
        24. **POSITIVE** ↔ **NEGATIVE**
        25. **ACTIVE** ↔ **PASSIVE**
        26. **EXPENSIVE** ↔ **CHEAP**
        27. **SAFE** ↔ **DANGEROUS**
        28. **HEALTHY** ↔ **SICK**
        29. **EARLY** ↔ **LATE**
        30. **BEGINNING** ↔ **END**
    """;
    mcq "synonym_quiz1" {
        Q: "Which word is a SYNONYM of 'ECSTATIC'?";
        A: "b) Overjoyed";
        O: a) "Sad", b) "Overjoyed", c) "Angry", d) "Tired";
        R: "ECSTATIC means extremely happy. Synonyms include: overjoyed, elated, thrilled, euphoric.";
        on_correct: {
            feedback: "Great! You understand synonyms!";
            goto "parts_of_speech";
        }
        on_wrong: {
            feedback: "ECSTATIC = extremely happy. Think of someone jumping for joy!";
            @loopback "synonyms_antonyms" {
                $synonym_attempts = $synonym_attempts + 1;
            }
        }
    }
}

scene "parts_of_speech" {    index: "f1";
    concept: "parts_of_speech";
    title: "Parts of Speech Identification";
    format: "markdown";
    body: """
        ## Identifying Parts of Speech
        
        Every word belongs to a category based on its function in a sentence.
        
        ### {bold}1. NOUNS (Naming Words){/bold}
        Name people, places, things, or ideas.
        
        **Examples:**
        - Person: teacher, student, doctor, artist, athlete
        - Place: school, city, country, park, restaurant
        - Thing: book, computer, car, house, phone
        - Idea: freedom, happiness, justice, love, courage
        
        **Clues:**
        - Can be preceded by articles (a, an, the)
        - Can be pluralized (add -s/-es)
        - Often answer: Who? or What?
        
        ### {bold}2. ADJECTIVES (Describing Words){/bold}
        Describe or modify nouns.
        
        **Examples:**
        - beautiful, intelligent, tall, fast, colorful, ancient
        - three, several, many, some, each, every
        - this, that, these, those
        
        **Clues:**
        - Answer: What kind? Which one? How many?
        - Often end in: -ful, -less, -ous, -ive, -able, -al, -ic
        - Come before nouns or after linking verbs
        
        ### {bold}3. VERBS (Action/State Words){/bold}
        Show action or state of being.
        
        **Examples:**
        - Action: run, jump, write, think, create, destroy
        - State: is, am, are, was, were, seem, become, appear
        
        **Clues:**
        - Can change tense (past, present, future)
        - Answer: What is happening?
        - Often end in: -ize, -ate, -en, -fy
        
        ### {bold}4. ADVERBS (Manner Words){/bold}
        Modify verbs, adjectives, or other adverbs.        
        **Examples:**
        - quickly, slowly, carefully, beautifully, easily
        - very, extremely, quite, rather, too
        - here, there, everywhere, now, then, soon
        
        **Clues:**
        - Often answer: How? When? Where? To what extent?
        - Many end in: -ly
        - Modify verbs, adjectives, or other adverbs
        
        ## {bold}Practice: Identify the Part of Speech{/bold}
        
        | Word | Noun | Adjective | Verb | Adverb |
        |------|------|-----------|------|--------|
        | QUICKLY | | | | ✓ |
        | BEAUTIFUL | | ✓ | | |
        | RUN | | | ✓ | |
        | HAPPINESS | ✓ | | | |
        | CAREFULLY | | | | ✓ |
        | INTELLIGENT | | ✓ | | |
        | CREATE | | | ✓ | |
        | FREEDOM | ✓ | | | |
        | SLOWLY | | | | ✓ |
        | POWERFUL | | ✓ | | |
        
        ## {bold}Words That Can Be Multiple Parts of Speech:{/bold}
        
        Many words can function as different parts of speech depending on context!
        
        **Examples:**
        
        1. **LIGHT**
           - Noun: Turn on the {color:blue}light{/color}.
           - Adjective: The box is {color:blue}light{/color}.
           - Verb: {color:blue}Light{/color} the candle.
        
        2. **FAST**
           - Adjective: He is a {color:blue}fast{/color} runner.
           - Adverb: She runs {color:blue}fast{/color}.
           - Verb: They {color:blue}fast{/color} during Ramadan.
        
        3. **BOOK**
           - Noun: I read a {color:blue}book{/color}.
           - Verb: {color:blue}Book{/color} your tickets early.
        
        4. **WELL**
           - Adjective: She is {color:blue}well{/color} now.
           - Adverb: He sings {color:blue}well{/color}.
           - Noun: Draw water from the {color:blue}well{/color}.        
        5. **RIGHT**
           - Adjective: That's the {color:blue}right{/color} answer.
           - Adverb: Turn {color:blue}right{/color}.
           - Noun: Everyone has {color:blue}rights{/color}.
    """;
    simulation "pos_identifier" {
        description: "Interactive Part of Speech Identifier";
        raw: """
            <div style="background:#e8f8f5;padding:20px;border-radius:10px;">
                <h3 style="color:#16a085;">Part of Speech Identifier</h3>
                <p>Test your ability to identify parts of speech!</p>
                <div id="posQuestion" style="background:white;padding:15px;margin:15px 0;border-radius:5px;">
                    <div style="font-size:18px;margin-bottom:10px;" id="sentence"></div>
                    <div style="color:#e74c3c;font-weight:bold;" id="targetWord"></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <button onclick="checkPOS('noun')" style="padding:10px;background:#3498db;color:white;border:none;border-radius:5px;cursor:pointer;">Noun</button>
                    <button onclick="checkPOS('adjective')" style="padding:10px;background:#9b59b6;color:white;border:none;border-radius:5px;cursor:pointer;">Adjective</button>
                    <button onclick="checkPOS('verb')" style="padding:10px;background:#e67e22;color:white;border:none;border-radius:5px;cursor:pointer;">Verb</button>
                    <button onclick="checkPOS('adverb')" style="padding:10px;background:#1abc9c;color:white;border:none;border-radius:5px;cursor:pointer;">Adverb</button>
                </div>
                <div id="posResult" style="margin-top:15px;padding:15px;background:white;border-radius:5px;display:none;"></div>
                <button onclick="nextPOSQuestion()" style="margin-top:15px;padding:10px 20px;background:#16a085;color:white;border:none;border-radius:5px;cursor:pointer;">Next Question</button>
            </div>
            <script>
                const posQuestions = [
                    {sentence: "She runs QUICKLY to catch the bus.", word: "QUICKLY", answer: "adverb", explanation: "QUICKLY modifies the verb 'runs' - tells HOW she runs."},
                    {sentence: "The BEAUTIFUL garden bloomed in spring.", word: "BEAUTIFUL", answer: "adjective", explanation: "BEAUTIFUL describes the noun 'garden' - tells WHAT KIND."},
                    {sentence: "They CREATE amazing artwork.", word: "CREATE", answer: "verb", explanation: "CREATE is an action word - shows what they DO."},
                    {sentence: "HAPPINESS is important for health.", word: "HAPPINESS", answer: "noun", explanation: "HAPPINESS is a thing/idea - the subject of the sentence."},
                    {sentence: "He spoke CAREFULLY about the topic.", word: "CAREFULLY", answer: "adverb", explanation: "CAREFULLY modifies the verb 'spoke' - tells HOW he spoke."},
                    {sentence: "The INTELLIGENT student solved the problem.", word: "INTELLIGENT", answer: "adjective", explanation: "INTELLIGENT describes the noun 'student' - tells WHAT KIND."},
                    {sentence: "Freedom is a precious gift.", word: "Freedom", answer: "noun", explanation: "Freedom is an idea/concept - the subject of the sentence."},
                    {sentence: "She is extremely TALENTED.", word: "TALENTED", answer: "adjective", explanation: "TALENTED describes 'She' - follows linking verb 'is'."}
                ];
                let currentQ = 0;
                
                function loadQuestion() {
                    const q = posQuestions[currentQ];
                    document.getElementById('sentence').textContent = q.sentence;
                    document.getElementById('targetWord').textContent = 'Identify: ' + q.word;
                    document.getElementById('posResult').style.display = 'none';
                }
                
                function checkPOS(answer) {
                    const q = posQuestions[currentQ];
                    const resultDiv = document.getElementById('posResult');
                    resultDiv.style.display = 'block';
                    if (answer === q.answer) {                        resultDiv.innerHTML = '<span style="color:#27ae60;font-weight:bold;">✓ Correct!</span><br>' + q.explanation;
                        resultDiv.style.background = '#d5f5e3';
                    } else {
                        resultDiv.innerHTML = '<span style="color:#e74c3c;font-weight:bold;">✗ Incorrect</span><br>' + q.explanation;
                        resultDiv.style.background = '#fadbd8';
                    }
                }
                
                function nextPOSQuestion() {
                    currentQ = (currentQ + 1) % posQuestions.length;
                    loadQuestion();
                }
                
                loadQuestion();
            </script>
        """;
    }
    mcq "pos_quiz1" {
        Q: "In the sentence 'She sings BEAUTIFULLY', what part of speech is 'BEAUTIFULLY'?";
        A: "d) Adverb";
        O: a) "Noun", b) "Adjective", c) "Verb", d) "Adverb";
        R: "BEAUTIFULLY modifies the verb 'sings' - it tells HOW she sings. Words ending in -ly that modify verbs are adverbs.";
        on_correct: {
            feedback: "Perfect! You can identify parts of speech!";
            goto "comprehensive_examples";
        }
        on_wrong: {
            feedback: "Remember: -LY words that modify verbs are ADVERBS (quickly, slowly, carefully).";
            @loopback "parts_of_speech" {
                $pos_attempts = $pos_attempts + 1;
            }
        }
    }
}

scene "comprehensive_examples" {
    index: "g1";
    concept: "vocabulary_application";
    title: "100+ Comprehensive Examples";
    format: "markdown";
    body: """
        ## Complete Word Analysis Examples (1-50)
        
        ### Analyzing Word Structure:
        
        1. **UNPREDICTABLE**
           - Prefix: UN- (not)
           - Root: DICT (say/speak) → PREDICT (say before)
           - Suffix: -ABLE (capable of)
           - Part of Speech: Adjective           - Meaning: Not capable of being said beforehand
           - Synonyms: uncertain, unpredictable, random
           - Antonyms: predictable, certain, foreseeable
        
        2. **INTERNATIONAL**
           - Prefix: INTER- (between)
           - Root: NAT (birth/nation)
           - Suffix: -AL (relating to)
           - Part of Speech: Adjective
           - Meaning: Relating to between nations
           - Synonyms: global, worldwide, universal
           - Antonyms: national, local, domestic
        
        3. **BIODEGRADABLE**
           - Prefix: BIO- (life)
           - Root: DE- (down) + GRAD (step)
           - Suffix: -ABLE (capable of)
           - Part of Speech: Adjective
           - Meaning: Capable of being broken down by living organisms
           - Synonyms: decomposable, compostable
           - Antonyms: non-biodegradable, permanent
        
        4. **MISUNDERSTANDING**
           - Prefix: MIS- (wrongly)
           - Root: UNDER (below) + STAND (stand)
           - Suffix: -ING (action/state)
           - Part of Speech: Noun
           - Meaning: The act of understanding wrongly
           - Synonyms: confusion, misinterpretation
           - Antonyms: understanding, comprehension
        
        5. **RECONSTRUCTION**
           - Prefix: RE- (again)
           - Root: STRUCT (build)
           - Suffix: -ION (action/state)
           - Part of Speech: Noun
           - Meaning: The act of building again
           - Synonyms: rebuilding, renovation
           - Antonyms: destruction, demolition
           
        *(Continues with 95 more examples in the full lesson text...)*
    """;
    goto "examples_51_100";
}

scene "examples_51_100" {
    index: "g2";
    concept: "vocabulary_application";
    title: "Examples 51-100+ with MCQs";
    format: "markdown";    body: """
        ## More Comprehensive Examples (51-100)
        
        51. **UNFAIR** = UN- (not) + FAIR → Adjective → Not fair
        52. **REBUILD** = RE- (again) + BUILD → Verb → Build again
        53. **DISLIKE** = DIS- (opposite) + LIKE → Verb → Opposite of like
        54. **PREVIEW** = PRE- (before) + VIEW → Noun/Verb → View before
        55. **SUBWAY** = SUB- (under) + WAY → Noun → Under way/road
        56. **INTERVIEW** = INTER- (between) + VIEW → Noun/Verb → See between (meeting)
        57. **MISLEAD** = MIS- (wrongly) + LEAD → Verb → Lead wrongly
        58. **OVERWORK** = OVER- (too much) + WORK → Verb/Noun → Work too much
        59. **UNDERCOOK** = UNDER- (too little) + COOK → Verb → Cook too little
        60. **SUPERMARKET** = SUPER- (above/large) + MARKET → Noun → Large market
        
        *(Examples 61-100 follow similar structural breakdowns...)*
        
        ### {bold}Quick Reference - Common Patterns:{/bold}
        
        **Negative Prefixes:**
        - UN-, IN-/IM-/IL-/IR-, DIS-, NON-, MIS-
        
        **Number Prefixes:**
        - UNI- (1), BI- (2), TRI- (3), MULTI- (many), SEMI- (half)
        
        **Position Prefixes:**
        - PRE- (before), POST- (after), SUB- (under), SUPER- (above)
        - INTER- (between), TRANS- (across), INTRA- (within)
        
        **Common Suffixes by Part of Speech:**
        - Nouns: -TION, -MENT, -NESS, -ITY, -ER/-OR, -ISM
        - Adjectives: -FUL, -LESS, -ABLE, -OUS, -IVE, -AL, -IC
        - Verbs: -IZE, -ATE, -EN, -FY
        - Adverbs: -LY
    """;
    mcq "comprehensive_quiz1" {
        Q: "What does 'BENEFACTOR' mean?";
        A: "b) One who does good";
        O: a) "One who does harm", b) "One who does good", c) "One who takes", d) "One who leads";
        R: "BENE (good) + FACT (do) + -OR (person who) = One who does good. Think: benefactor donates to charity.";
        on_correct: {
            feedback: "Excellent! You're analyzing complex words!";
            goto "speed_techniques";
        }
        on_wrong: {
            feedback: "Remember: BENE = good (benefit, benevolent, benefactor)";
            @loopback "examples_51_100" {
                $comprehensive_attempts = $comprehensive_attempts + 1;
            }
        }
    }}

scene "speed_techniques" {
    index: "h1";
    concept: "test_strategies";
    title: "Speed-Solving Techniques for Aptitude Tests";
    format: "markdown";
    body: """
        ## {bold}⚡ Fast Problem-Solving Strategies (30-Second Rules){/bold}
        
        ### {bold}Technique 1: The 3-Second Prefix Scan{/bold}
        When you see an unfamiliar word, immediately look for:
        - See UN-, DIS-, IN-? → Probably NEGATIVE meaning
        - See RE-? → Means AGAIN
        - See PRE-? → Means BEFORE
        - See MIS-? → Means WRONG
        
        ### {bold}Technique 2: Root Word Recognition (10 seconds){/bold}
        Memorize high-frequency roots like SPECT (look), DICT (say), PORT (carry).
        
        ### {bold}Technique 3: Suffix = Part of Speech (5 seconds){/bold}
        - Ends in -LY? → ADVERB
        - Ends in -TION/-MENT/-NESS? → NOUN
        - Ends in -FUL/-LESS/-ABLE/-OUS? → ADJECTIVE
        - Ends in -IZE/-ATE/-EN? → VERB
    """;
    mcq "speed_quiz1" {
        Q: "Using speed techniques: What does 'INVISIBLE' mean in 10 seconds?";
        A: "b) Not able to be seen";
        O: a) "Very visible", b) "Not able to be seen", c) "Somewhat visible", d) "Clearly visible";
        R: "IN- (not) + VIS (see) + -IBLE (able to) = Not able to be seen. Use Technique 1 & 2!";
        on_correct: {
            feedback: "Perfect! You're mastering speed techniques!";
            goto "final_assessment";
        }
        on_wrong: {
            feedback: "Practice: IN- = not, VIS = see. INVISIBLE = not seeable.";
            @loopback "speed_techniques" {
                $speed_attempts = $speed_attempts + 1;
            }
        }
    }
}

scene "final_assessment" {
    index: "i1";
    concept: "comprehensive_assessment";
    title: "Final Comprehensive Assessment";
    format: "markdown";
    body: """        ## {bold}🎓 Final Vocabulary Mastery Test{/bold}
        
        You've learned:
        - ✅ 100+ word examples
        - ✅ Root words, prefixes, suffixes
        - ✅ Synonyms and antonyms
        - ✅ Parts of speech identification
        - ✅ Speed-solving techniques
        
        Now test your mastery!
    """;
    mcq "final_q1" {
        Q: "What is the root word in 'CONSTRUCTION' and what does it mean?";
        A: "b) STRUCT = build";
        O: a) "CON = with", b) "STRUCT = build", c) "TION = action", d) "STRUC = strong";
        R: "STRUCT is the root meaning 'build'. CON- is prefix (together), -ION is suffix (process).";
        on_correct: {
            feedback: "Excellent!";
            goto "final_q2";
        }
        on_wrong: {
            feedback: "Review: STRUCT = build (construct, instruct, destruction)";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

scene "final_q2" {
