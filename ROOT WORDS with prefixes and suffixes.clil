    concept: "comprehensive_assessment";
    mcq "final_q2" {
        Q: "Which word is a SYNONYM of 'MELANCHOLY'?";
        A: "b) Sad";
        O: a) "Happy", b) "Sad", c) "Angry", d) "Excited";
        R: "MELANCHOLY means deep sadness. Synonyms: sorrowful, gloomy, dejected.";
        on_correct: {
            feedback: "Great!";
            goto "final_q3";
        }
        on_wrong: {
            feedback: "MELANCHOLY = deep sadness (see synonyms section)";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}
scene "final_q3" {
    index: "i3";
    concept: "comprehensive_assessment";
    mcq "final_q3" {
        Q: "What part of speech is 'QUICKLY' in 'She runs quickly'?";
        A: "d) Adverb";
        O: a) "Noun", b) "Adjective", c) "Verb", d) "Adverb";
        R: "QUICKLY modifies the verb 'runs' (tells HOW). -LY words modifying verbs are adverbs.";
        on_correct: {
            feedback: "Perfect!";
            goto "final_q4";
        }
        on_wrong: {
            feedback: "-LY words that modify verbs are ADVERBS";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

scene "final_q4" {
    index: "i4";
    concept: "comprehensive_assessment";
    mcq "final_q4" {
        Q: "What does the prefix 'MIS-' mean in 'MISBEHAVE'?";
        A: "b) Wrongly";
        O: a) "Again", b) "Wrongly", c) "Before", d) "After";
        R: "MIS- means 'wrongly' or 'badly'. Misbehave = behave wrongly.";
        on_correct: {
            feedback: "Excellent!";
            goto "final_q5";
        }
        on_wrong: {
            feedback: "MIS- = wrongly (misunderstand, mislead, misplace)";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

scene "final_q5" {
    index: "i5";
    concept: "comprehensive_assessment";
    mcq "final_q5" {
        Q: "What is the antonym of 'ANCIENT'?";
        A: "b) Modern";
        O: a) "Old", b) "Modern", c) "Historic", d) "Antique";
        R: "ANCIENT means very old. The opposite is MODERN (very new/recent).";        on_correct: {
            feedback: "Great job!";
            goto "final_q6";
        }
        on_wrong: {
            feedback: "ANCIENT = very old, so antonym = very new = MODERN";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

scene "final_q6" {
    index: "i6";
    concept: "comprehensive_assessment";
    mcq "final_q6" {
        Q: "Which suffix would make 'BEAUTY' into an adjective?";
        A: "c) -FUL";
        O: a) "-NESS", b) "-MENT", c) "-FUL", d) "-TION";
        R: "-FUL creates adjectives. BEAUTY + FUL = BEAUTIFUL (adjective). -NESS makes nouns.";
        on_correct: {
            feedback: "Perfect!";
            goto "final_q7";
        }
        on_wrong: {
            feedback: "-FUL makes adjectives (beautiful, helpful, careful)";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

scene "final_q7" {
    index: "i7";
    concept: "comprehensive_assessment";
    mcq "final_q7" {
        Q: "What does 'BIOGRAPHY' mean?";
        A: "b) Writing about life";
        O: a) "Study of life", b) "Writing about life", c) "Life force", d) "Living thing";
        R: "BIO (life) + GRAPH (write) + -Y = Writing about someone's life.";
        on_correct: {
            feedback: "Excellent!";
            goto "final_q8";
        }
        on_wrong: {
            feedback: "BIO = life, GRAPH = write. Biography = life writing";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;            }
        }
    }
}

scene "final_q8" {
    index: "i8";
    concept: "comprehensive_assessment";
    mcq "final_q8" {
        Q: "In 'UNPREDICTABLE', what does the prefix 'UN-' mean?";
        A: "b) Not";
        O: a) "Again", b) "Not", c) "Before", d) "After";
        R: "UN- is a negative prefix meaning 'not'. Unpredictable = not predictable.";
        on_correct: {
            feedback: "Great!";
            goto "completion";
        }
        on_wrong: {
            feedback: "UN- = not (unhappy, unfair, unknown)";
            @loopback "final_assessment" {
                $final_attempts = $final_attempts + 1;
            }
        }
    }
}

